# Copy this file to .env before using Docker Compose.
# Replace all placeholder secrets; do not commit .env.
# Model artifacts are not configured here: compose stores them in ./workdir/models.

# Shared secret required for worker registration with the controller.
LCOAL_WORKER_REGISTRATION_TOKEN=replace-with-a-long-random-worker-registration-token

# Stable HMAC secret for signed upload URLs. If omitted, old URLs fail after restart.
LCOAL_UPLOAD_SIGNING_SECRET=replace-with-a-long-random-upload-signing-secret

# Admin token for protected admin operations. Send as x-lcoal-admin-token or Bearer token.
LCOAL_ADMIN_TOKEN=replace-with-a-long-random-admin-token

# Public URL clients use for controller-generated upload URLs.
LCOAL_PUBLIC_BASE_URL=http://127.0.0.1:17890
