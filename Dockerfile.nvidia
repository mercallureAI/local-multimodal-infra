FROM nvidia/cuda:12.8.1-cudnn-runtime-ubuntu24.04@sha256:ac55d124da4882b497f732d8dfd9a702d5447a5f29d08d56da6f64f0a1eb34bc AS builder

ARG ORT_CUDA_VERSION=12
RUN test "${ORT_CUDA_VERSION}" = "12"
ENV ORT_CUDA_VERSION=${ORT_CUDA_VERSION}
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl build-essential pkg-config \
    && rm -rf /var/lib/apt/lists/* \
    && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --profile minimal --default-toolchain 1.88.0 \
    && rustc --version \
    && cargo --version

COPY . .
# The cuda feature selects ort-sys' CUDA archive; --locked fixes all Cargo inputs.
RUN cargo build --locked --release -p local-cli --bin worker --features cuda
RUN set -eux; \
    mkdir -p /ort-libs; \
    find /app/target -name 'libonnxruntime*.so*' ! -name '*tensorrt*' -exec cp -Lv {} /ort-libs/ \;; \
    test -e /ort-libs/libonnxruntime_providers_cuda.so

# Use Ubuntu 24.04 for both stages: glibc 2.39 satisfies the CUDA archive's
# GLIBC_2.38 symbols, while keeping the runtime CUDA and cuDNN versions fixed.
FROM nvidia/cuda:12.8.1-cudnn-runtime-ubuntu24.04@sha256:ac55d124da4882b497f732d8dfd9a702d5447a5f29d08d56da6f64f0a1eb34bc

WORKDIR /app
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libgomp1 libstdc++6 \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /app/workdir/models

COPY --from=builder /app/target/release/worker /usr/local/bin/worker
COPY --from=builder /ort-libs/ /usr/local/lib/
COPY configs ./configs
RUN set -eux; \
    ldconfig; \
    test -x /usr/local/bin/worker; \
    test -e /usr/local/lib/libonnxruntime_providers_cuda.so; \
    for file in \
        /usr/local/bin/worker \
        /usr/local/lib/libonnxruntime_providers_cuda.so; do \
        ldd "${file}" | tee /tmp/ldd.txt; \
        ! grep -q 'not found' /tmp/ldd.txt; \
    done

ENV ORT_CUDA_VERSION=12
ENV RUST_LOG=info
